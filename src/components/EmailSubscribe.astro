---
---

<section class="email-subscribe">
    <p class="email-subscribe-text">Get notified when I publish new dispatches.</p>
    <form class="email-subscribe-form" aria-label="Email subscription">
        <input
            type="email"
            name="email"
            placeholder="your@email.com"
            required
            autocomplete="email"
            class="email-subscribe-input"
        />
        <button type="submit" class="email-subscribe-button">Subscribe</button>
    </form>
    <p class="email-subscribe-success" aria-live="polite" hidden>
        Thanks for subscribing! You will hear from me soon.
    </p>
</section>

<script>
    document.addEventListener('astro:page-load', () => {
        const forms = document.querySelectorAll<HTMLFormElement>('.email-subscribe-form');
        forms.forEach((form) => {
            form.addEventListener('submit', (e) => {
                e.preventDefault();
                const section = form.closest('.email-subscribe');
                if (!section) return;
                const success = section.querySelector('.email-subscribe-success');
                if (!success) return;
                form.hidden = true;
                (success as HTMLElement).hidden = false;
            });
        });
    });
</script>

<style>
    .email-subscribe {
        margin-top: 3rem;
        padding: 2rem;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        text-align: center;
    }

    .email-subscribe-text {
        margin: 0 0 1rem;
        color: var(--secondary-color);
        font-size: 0.95rem;
    }

    .email-subscribe-form {
        display: flex;
        gap: 0.5rem;
        justify-content: center;
        max-width: 420px;
        margin: 0 auto;
    }

    .email-subscribe-input {
        flex: 1;
        padding: 0.6rem 0.8rem;
        font-family: 'JetBrains Mono', 'Fira Code', monospace;
        font-size: 0.88rem;
        color: var(--text-color);
        background: var(--bg-color);
        border: 1px solid var(--border-color);
        border-radius: 4px;
        outline: none;
    }

    .email-subscribe-input:focus {
        border-color: var(--accent-color);
    }

    .email-subscribe-input::placeholder {
        color: var(--secondary-color);
        opacity: 0.7;
    }

    .email-subscribe-button {
        padding: 0.6rem 1.2rem;
        font-family: 'JetBrains Mono', 'Fira Code', monospace;
        font-size: 0.88rem;
        color: var(--bg-color);
        background: var(--accent-color);
        border: none;
        border-radius: 4px;
        cursor: pointer;
        white-space: nowrap;
    }

    .email-subscribe-button:hover {
        opacity: 0.85;
    }

    .email-subscribe-success {
        margin: 0;
        color: var(--mono-green, #a9dc76);
        font-size: 0.95rem;
    }

    @media (max-width: 480px) {
        .email-subscribe-form {
            flex-direction: column;
        }
    }
</style>
