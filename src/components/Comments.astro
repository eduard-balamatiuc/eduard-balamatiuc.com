---
/**
 * Comments component powered by giscus (https://giscus.app).
 *
 * Before this works, the repository owner must:
 *   1. Enable GitHub Discussions on the repository (Settings > General > Features > Discussions).
 *   2. Install the giscus GitHub App: https://github.com/apps/giscus
 *   3. Visit https://giscus.app, enter the repo name, and copy the generated
 *      data-repo-id and data-category-id values into the placeholders below.
 */
---

<section class="comments-section">
    <h2>Comments</h2>
    <script
        src="https://giscus.app/client.js"
        data-repo="eduard-balamatiuc/eduard-balamatiuc.com"
        data-repo-id="REPLACE_WITH_REPO_ID"
        data-category="Announcements"
        data-category-id="REPLACE_WITH_CATEGORY_ID"
        data-mapping="pathname"
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="top"
        data-theme="dark"
        data-lang="en"
        data-loading="lazy"
        crossorigin="anonymous"
        async
    ></script>
</section>

<script>
    function getGiscusTheme(): string {
        return document.documentElement.classList.contains("light-theme")
            ? "light"
            : "dark";
    }

    function setGiscusTheme(theme: string): void {
        const iframe = document.querySelector<HTMLIFrameElement>(
            "iframe.giscus-frame",
        );
        if (!iframe?.contentWindow) return;

        iframe.contentWindow.postMessage(
            { giscus: { setConfig: { theme } } },
            "https://giscus.app",
        );
    }

    // Set the correct theme once the giscus iframe has loaded.
    window.addEventListener("message", (event) => {
        if (event.origin !== "https://giscus.app") return;

        const giscusData =
            typeof event.data === "object" && event.data?.giscus;
        if (!giscusData) return;

        // The iframe just loaded — sync to current site theme.
        setGiscusTheme(getGiscusTheme());
    });

    // Listen for the site's theme toggle clicks.
    const themeToggle = document.querySelector(".theme-toggle");
    if (themeToggle) {
        themeToggle.addEventListener("click", () => {
            // The color-theme.js handler toggles the class before we run,
            // so by the next tick the class reflects the new theme.
            requestAnimationFrame(() => {
                setGiscusTheme(getGiscusTheme());
            });
        });
    }
</script>

<style>
    .comments-section {
        margin-top: 4rem;
        padding-top: 2rem;
        border-top: 1px solid var(--border-color);
    }

    .comments-section h2 {
        margin-bottom: 1.5rem;
    }
</style>
